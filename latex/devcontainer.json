{
  "name": "LaTeX",
  "image": "ghcr.io/benni-tec/devcontainers-latex:main",
  "postCreateCommand": "tlmgr update --self && /usr/local/bin/setup_tlmgr.sh && texhash",
  "customizations": {
    "vscode": {
      "extensions": [
        "James-Yu.latex-workshop"
      ],
      "settings": {
        "latex-workshop.latex.recipe.default": "lualatex",
        "latex-workshop.latex.tools": [
          {
            "name": "lualatex",
            "command": "lualatex",
            "args": [
              "-interaction=nonstopmode",
              "-synctex=1",
              "%DOC%"
            ]
          },
          {
            "name": "lualatex-noerror",
            "command": "bash",
            "args": [
              "-c",
              "lualatex -interaction=nonstopmode -synctex=1 %DOC% || true"
            ]
          },
          {
            "name": "biber",
            "command": "biber",
            "args": [
              "%DOCFILE%"
            ]
          }
        ],
        "latex-workshop.latex.recipes": [
          {
            "name": "lualatex",
            "tools": [
              "lualatex"
            ]
          },
          {
            "name": "lualatex ➞ biber ➞ lualatex x2",
            "tools": [
              "lualatex-noerror",
              "biber",
              "lualatex-noerror",
              "lualatex"
            ]
          },
          {
            "name": "biber",
            "tools": [
              "biber"
            ]
          }
        ]
      }
    },
    "jetbrains": {
      "plugins": [
        "nl.hannahsten.texifyidea"
      ]
    }
  }
}